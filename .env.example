# RecDesk AI Backend - Environment Variables
# =============================================
# This file documents all environment variables used by the backend.
# Copy this file to .env and fill in your values.
#
# Environments:
#   - dev: Local development (everything runs on your laptop)
#   - production: Live environment (Railway + Vercel)

# =============================================================================
# APPLICATION
# =============================================================================
# Environment: development | production
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Frontend URL (for CORS and redirects)
# Comma-separated list of allowed origins. Include BOTH the tenant app and the
# super-admin console.
# dev: http://localhost:3001,http://localhost:3002
# production: https://recdesk.io,https://admin.recdesk.io
FRONTEND_URL=http://localhost:3001,http://localhost:3002

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
# dev: Local PostgreSQL
# production: Railway PostgreSQL (auto-generated DATABASE_URL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/recdesk?schema=public&connection_limit=10&pool_timeout=20"

# =============================================================================
# REDIS (Caching & Queues)
# =============================================================================
# Redis is OPTIONAL - the app gracefully falls back to in-memory cache when not configured.
#
# Local Development:
#   Start Redis with: docker-compose up -d
#   Then set REDIS_HOST=localhost
#
# Production (Railway):
#   1. Add Redis addon in Railway dashboard
#   2. Railway auto-injects REDIS_URL (no manual config needed)
#
# Choose ONE of these options:
# Option A: Use REDIS_URL (preferred for Railway/cloud)
# REDIS_URL=redis://default:password@host:port
#
# Option B: Use individual settings (for local Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# CRITICAL: Use a strong secret in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Password Hashing
BCRYPT_SALT_ROUNDS=10

# =============================================================================
# PLATFORM SUPER-ADMIN (Control Room console)
# =============================================================================
# SEPARATE secret from JWT_SECRET so platform tokens and tenant tokens are never
# interchangeable. Platform admins live in the isolated `platform_admins` table.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Bootstrap the first admin:
#   npm run platform-admin -- --email=ops@recdesk.io --password='StrongPass123!'
PLATFORM_JWT_SECRET=your-platform-super-secret-change-in-production
# Production (set in Railway / prod env):
# PLATFORM_JWT_SECRET_PROD=your-prod-platform-secret
# Optional token lifetimes (seconds); defaults: 900 access / 604800 refresh
# PLATFORM_JWT_ACCESS_EXPIRATION_SECONDS=900
# PLATFORM_JWT_REFRESH_EXPIRATION_SECONDS=604800

# =============================================================================
# AWS S3 (File Storage)
# =============================================================================
# dev: recdesk-cvs-dev (or use local fallback)
# production: recdesk-cvs-prod
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=recdesk-cvs-dev

# Set to 'true' to use local file storage instead of S3 (for dev without AWS)
S3_USE_LOCAL_FALLBACK=true

# =============================================================================
# AI PROVIDER (OpenAI - active for local + production)
# =============================================================================
# Provider: openai (higher accuracy, model gpt-4o) or groq (cost-effective fallback)
# OpenAI uses a single API key valid in both local and production environments.
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key

# Groq (optional fallback - flip AI_PROVIDER=groq to use)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================
# EMAIL SERVICE (AWS SES)
# =============================================================================
# AWS credentials are REUSED from the "AWS S3" section above
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY). The IAM user/role must have
# the ses:SendEmail permission.
#
# IMPORTANT: SES_FROM_EMAIL must be a VERIFIED SES identity (email or domain).
# For production sending to arbitrary recipients, the account must be moved
# out of the SES sandbox.
#
# SES_REGION defaults to AWS_REGION when omitted (SES is region-specific).

# Local Development
SES_REGION=eu-central-1
SES_FROM_EMAIL=noreply@recdesk.io

# Production (set these in your production environment)
# SES_REGION_PROD=eu-central-1
# SES_FROM_EMAIL_PROD=noreply@recdesk.io

# =============================================================================
# GMAIL OAUTH (Email Integration)
# =============================================================================
# Two separate OAuth clients:
#   - RecDesk-mail-integration-local  → for local development
#   - RecDesk-mail-integration-prod   → for production
#
# Redirect URIs:
#   dev: http://localhost:3000/api/integrations/gmail/callback
#   production: https://api.recdesk.io/api/integrations/gmail/callback

# Local Development
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback

# Production (set in Railway)
# GOOGLE_CLIENT_ID_PROD=your-prod-google-client-id
# GOOGLE_CLIENT_SECRET_PROD=your-prod-google-client-secret
# GOOGLE_REDIRECT_URI_PROD=https://api.recdesk.io/api/integrations/gmail/callback

# Gmail Pub/Sub Push Notifications (real-time email capture)
# Push is auto-enabled when GOOGLE_PUBSUB_TOPIC is set; omit to use polling only.
# Local Development
GOOGLE_PUBSUB_TOPIC=projects/your-project-dev/topics/gmail-notifications
GMAIL_PUBSUB_VERIFICATION_TOKEN=your-dev-verification-token
# Production (set in Railway)
# GOOGLE_PUBSUB_TOPIC_PROD=projects/your-project-prod/topics/gmail-notifications
# GMAIL_PUBSUB_VERIFICATION_TOKEN_PROD=your-prod-verification-token

# =============================================================================
# MICROSOFT OUTLOOK EMAIL INTEGRATION (Graph API)
# =============================================================================
# Azure AD App Registration for Outlook email capture (separate from user auth)
# Multi-tenant app with delegated permissions: Mail.Read, User.Read, offline_access
#
# Setup: https://portal.azure.com -> Azure Active Directory -> App registrations
# Redirect URI: http://localhost:3000/api/integrations/outlook/callback (dev)
#               https://api.recdesk.io/api/integrations/outlook/callback (prod)

# Local Development
MICROSOFT_EMAIL_CLIENT_ID=your-azure-email-client-id
MICROSOFT_EMAIL_CLIENT_SECRET=your-azure-email-client-secret
MICROSOFT_EMAIL_REDIRECT_URI=http://localhost:3000/api/integrations/outlook/callback
MICROSOFT_EMAIL_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app/api/webhooks/outlook
MICROSOFT_EMAIL_WEBHOOK_SECRET=your-webhook-client-state-secret

# Production (set in Railway)
# MICROSOFT_EMAIL_CLIENT_ID_PROD=your-prod-azure-email-client-id
# MICROSOFT_EMAIL_CLIENT_SECRET_PROD=your-prod-azure-email-client-secret
# MICROSOFT_EMAIL_REDIRECT_URI_PROD=https://api.recdesk.io/api/integrations/outlook/callback
# MICROSOFT_EMAIL_WEBHOOK_URL_PROD=https://api.recdesk.io/api/webhooks/outlook
# MICROSOFT_EMAIL_WEBHOOK_SECRET_PROD=your-prod-webhook-client-state-secret

# =============================================================================
# ENCRYPTION
# =============================================================================
# 32-byte key (64 hex characters) for AES-256-GCM encryption of OAuth tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Keep this key safe. Losing it means all encrypted tokens become unreadable.
ENCRYPTION_KEY=your-64-hex-char-encryption-key-generate-with-command-above!

# =============================================================================
# STRIPE (Billing)
# =============================================================================
# dev: Use test keys (sk_test_xxx)
# production: Use live keys (sk_live_xxx)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (create in Stripe Dashboard, configure in EGP currency)
STRIPE_STARTER_PRICE_ID=price_starter
STRIPE_PROFESSIONAL_PRICE_ID=price_professional
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise

# =============================================================================
# EMAIL PREFILTER (Cost Optimization)
# =============================================================================
# Reduces AI API costs by 50-80% by skipping obvious non-job-application emails
PREFILTER_ENABLED=true
PREFILTER_AUTO_CLASSIFY_ENABLED=true

# =============================================================================
# WAITLIST
# =============================================================================
# Send a welcome email when someone joins the waitlist (uses AWS SES)
WAITLIST_WELCOME_EMAIL_ENABLED=true

# =============================================================================
# ACCESS ALLOWLIST (gates registration + login)
# =============================================================================
# Only emails matching an entry in the `allowed_emails` table may register or
# sign in (email/password AND Google/Microsoft OAuth). The values below are
# comma-separated and used ONLY to seed the table on startup so the first
# admins can get in. Use whole domains ("@acme.com" or "acme.com") or exact
# emails ("owner@acme.com"). Manage entries at runtime with:
#   npm run allowlist -- --add=owner@acme.com
#   npm run allowlist -- --add=@acme.com
#   npm run allowlist -- --list
# Local development seed:
AUTH_ALLOWLIST=
# Production seed (falls back to AUTH_ALLOWLIST when unset):
AUTH_ALLOWLIST_PROD=
